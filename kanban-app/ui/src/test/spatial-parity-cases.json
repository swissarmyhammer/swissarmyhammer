[
  {
    "name": "focus sets focused_key and emits event",
    "steps": [
      {
        "op": { "op": "push_layer", "key": "L1", "name": "window" },
        "expect": { "event": null, "focused": null }
      },
      {
        "op": {
          "op": "register",
          "entry": {
            "key": "k1",
            "moniker": "task:01",
            "rect": { "x": 0.0, "y": 0.0, "w": 100.0, "h": 50.0 },
            "layer_key": "L1",
            "parent_scope": null,
            "overrides": {}
          }
        },
        "expect": { "event": null, "focused": null }
      },
      {
        "op": { "op": "focus", "key": "k1" },
        "expect": {
          "event": { "prev_key": null, "next_key": "k1" },
          "focused": "k1"
        }
      }
    ]
  },

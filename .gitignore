.validators/

# Kanban perspective trash (local cleanup, not source)
.kanban/perspectives/.trash/

# Stray fixture output at workspace root.
# `agent-client-protocol-extras::get_fixture_path_for()` resolves to the
# per-crate `<crate>/.fixtures/` layout (acp-conformance,
# agent-client-protocol-extras, avp-common — all intentionally tracked). The
# workspace-root `.fixtures/` directory should never appear in a clean tree;
# this ignore line keeps any historical/accidental drop quiet.
/.fixtures/

# Test workflow files (not part of the project source)
builtin/workflows/*-test.md

# Python bytecode caches (helper scripts under scripts/)
__pycache__/

# Node.js — ignore lockfiles by default, but COMMIT the app UI lockfiles so CI
# (`npm ci`) installs a deterministic dep set. Unpinned `npm install` lets a
# freshly-published transitive dep silently break a green build with no code
# change (see the radix dismissable-layer regression, 2026-06).
package-lock.json
!apps/kanban-app/ui/package-lock.json
!apps/mirdan-app/ui/package-lock.json
node_modules/
# Reject pnpm lockfiles entirely — Tauri apps enforce npm via `only-allow npm`.
pnpm-lock.yaml

# Output scratch files
output_*.txt

test_validation

# Claude Code usage tracking files
cc.json
.llama-sessions

.acp


# Generated man pages (built at compile time, included in release archives)
docs/*.1

# AVP and shell tool dirs self-manage their own .gitignore

# Lockfiles (generated during install, project-specific)
avp-lock.json
mirdan-lock.json



